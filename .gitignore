# --- Скомпилированные бинарники (Go) ---
# Мы не пушим готовые программы, только исходный код
bin/
*.exe
*-linux
*-windows
mon-agent
mon-server

# --- Зависимости Go ---
# Сами пакеты скачиваются через go mod, их хранить не нужно
vendor/

# --- Фронтенд (Node.js / React) ---
# Эта папка весит сотни мегабайт, её нельзя пушить!
node_modules/
dist/
build/
.eslintcache

# --- Базы данных ---
# Если используешь SQLite, не пушь саму базу с данными
*.db
*.db-journal

# --- Конфиденциальные данные ---
# Если появятся пароли или ключи в этих файлах
.env
.env.local

# --- Системные файлы ---
# Мусор от Windows и macOS
Thumbs.db
.DS_Store
desktop.ini

# --- IDE (VS Code / JetBrains) ---
.vscode/
.idea/
*.swp